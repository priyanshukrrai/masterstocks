# Angel One SmartAPI credentials (free with an Angel One account).
# Create an API key at https://smartapi.angelbroking.com/ -> "Create App"
# (choose the "Market Feeds" / trading app type).
ANGEL_API_KEY=your_api_key
ANGEL_CLIENT_CODE=your_client_code           # e.g. A123456
ANGEL_MPIN=your_login_pin                    # your Angel One login PIN (or password)
ANGEL_TOTP_SECRET=your_base32_totp_secret    # the secret shown when you enable TOTP/2FA

# Comma-separated list of sites allowed to call this service (your Vercel URL).
# Use * while testing, then lock it down, e.g. https://your-app.vercel.app
CORS_ORIGINS=*

# Optional: override index tokens only if Angel ever changes them.
# NIFTY_TOKEN=99926000
# BANKNIFTY_TOKEN=99926009
# SENSEX_TOKEN=99919000
