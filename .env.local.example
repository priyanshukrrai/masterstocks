# MasterStocks - premium market data API keys
# Copy this file to .env.local and fill in your keys, then `npm run build`.
# (All NEXT_PUBLIC_* values are inlined into the static export at build time.)
#
# You can also paste keys at runtime from the browser console without a rebuild:
#   localStorage.setItem("twelvedata_key", "YOUR_KEY")
#   localStorage.setItem("finnhub_key",   "YOUR_KEY")
#   localStorage.setItem("coingecko_key", "YOUR_DEMO_KEY")

# Twelve Data - premium unified quotes for US + Indian (NSE) stocks.
# Required for live Indian market prices. Free key: https://twelvedata.com/apikey
NEXT_PUBLIC_TWELVEDATA_KEY=

# Finnhub - US stock quotes (used when no Twelve Data key is set).
# A working key is bundled by default; override it here if you like.
NEXT_PUBLIC_FINNHUB_KEY=

# CoinGecko - crypto quotes. Works key-free; a Demo key reduces rate-limiting.
# Free demo key: https://www.coingecko.com/en/developers/dashboard
NEXT_PUBLIC_COINGECKO_KEY=

# Real-time service (optional) - the FastAPI Angel One proxy in /realtime.
# Set this to its deployed URL to make the India tab use true sub-second ticks
# instead of the ~15-min Yahoo feed. Leave blank to use the built-in Yahoo route.
# e.g. https://masterstocks-rt.onrender.com
NEXT_PUBLIC_REALTIME_API=
